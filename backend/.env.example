# ─────────────────────────────────────────────────────────
# ColorPro Environment Configuration
# Copy this file to .env and customize for your deployment
# ─────────────────────────────────────────────────────────

# SECURITY: Generate a unique key for production!
# Run: python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=django-insecure-colorpro-dev-key-change-in-production

# Set to True only for local development
DEBUG=True

# Comma-separated list of allowed hostnames
ALLOWED_HOSTS=*

# Frontend origin for CORS (comma-separated)
CORS_ORIGINS=http://localhost:3000

# Set True to allow any origin (dev only)
# CORS_ALLOW_ALL_ORIGINS=True

# Quality Gate Thresholds (CIEDE2000 delta-E values)
DELTA_E_WARN_THRESHOLD=0.6
DELTA_E_REJECT_THRESHOLD=0.8
